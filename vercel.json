{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix frontend",
  "buildCommand": "cd frontend && npm run build && mkdir -p ../dist && cp -r dist/. ../dist/",
  "outputDirectory": "dist",
  "regions": ["sin1"],
  "functions": {
    "api/index.py": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "backend/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron/archive-completed-tasks",
      "schedule": "0 3 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
