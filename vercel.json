{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "python -m pip install -r requirements.txt && cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build && rm -rf ../dist && cp -r dist ../dist",
  "outputDirectory": "dist",
  "functions": {
    "api/index.py": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "{backend/**,requirements.txt,api/requirements.txt}"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
