SECRET_KEY=change-this-secret-key-in-production

# Local development (default):
DATABASE_URL=sqlite:///./workmanager.db

# Production (Neon) — set in Vercel dashboard, not in git:
# NEON_BRANCH=production
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

DEBUG=true
EMAIL_ENABLED=false
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTO_SEED=true

# Vercel Blob — auto-set when Blob store is linked to the Vercel project:
# BLOB_READ_WRITE_TOKEN=
