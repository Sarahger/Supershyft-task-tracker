# Copy these into Vercel → Project → Settings → Environment Variables
# Do NOT commit real values. This file is safe to push.

DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
SECRET_KEY=generate-with-openssl-rand-hex-32
DEBUG=false
AUTO_SEED=true
EMAIL_ENABLED=false
FRONTEND_URL=https://YOUR-PROJECT.vercel.app
CORS_ORIGINS=https://YOUR-PROJECT.vercel.app

# Optional — Neon tooling reference only (app reads DATABASE_URL):
# NEON_BRANCH=production
# DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Auto-added when Vercel Blob is linked to the project:
# BLOB_READ_WRITE_TOKEN=
